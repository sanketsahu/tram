    "type": "git",
    "url": "git+https://github.com/sanketsahu/jetplane.git"
  },
  "bugs": "https://github.com/sanketsahu/jetplane/issues",
  "keywords": [
    "expo",
    "react-native",
    "metro",
    "bundler",
    "transform-cache",
    "content-addressed",
    "dev-server",
    "hmr",
    "monorepo",
    "cache"
  ],
  "bin": {
    "jetplane": "./bin/jetplane.mjs"
  },
  "exports": {
    "./transformer": "./src/jetplane-transformer.cjs",
    "./transform-service": "./src/transform-service.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  }
